old/

# Python training environment and artifacts
training/.venv/
training/data/
training/runs/
training/datasets/_downloads/
__pycache__/
*.pyc

# Trained weights (tracked models are the exported ONNX in models/)
*.pt
*.pth

# Model weights and the embedded ONNX Runtime shared library are fetched by
# scripts/fetch-models.sh / scripts/fetch-ortlib.sh (see models/MODELS_VERSION),
# not tracked in git. Keep models/classes.json tracked — it's a small text
# file, not a build artifact.
/models/*.onnx
/internal/ortlib/lib/*

# Built command binaries (go build drops these in the repo root)
/septima
/septima-bench
/septima-diag
/septima-annotate
/septima-panel-bootstrap
/septima-analyze
/septima-punctsweep

# Generated error-analysis artifact (regenerated by cmd/septima-analyze)
/analyze_bothwrong.tsv

# Local editor / OS cruft
.DS_Store
